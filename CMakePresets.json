{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF"
      }
    },
    {
      "name": "linux-ninja-release",
      "inherits": "base",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/linux-ninja-release",
      "installDir": "${sourceDir}/out/install/linux-ninja-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ARS_ENABLE_TESTS": "ON",
        "ARS_BUILD_APP": "ON"
      }
    },
    {
      "name": "windows-vs2022-release",
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/out/build/windows-vs2022-release",
      "installDir": "${sourceDir}/out/install/windows-vs2022-release",
      "architecture": {
        "value": "x64"
      },
      "cacheVariables": {
        "ARS_ENABLE_TESTS": "ON",
        "ARS_BUILD_APP": "ON"
      }
    },
    {
      "name": "linux-aarch64-release",
      "inherits": "base",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/linux-aarch64-release",
      "installDir": "${sourceDir}/out/install/linux-aarch64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux-gcc-aarch64.cmake",
        "ARS_ENABLE_TESTS": "ON",
        "ARS_BUILD_APP": "ON"
      }
    },
    {
      "name": "linux-to-windows-x64-release",
      "inherits": "base",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/linux-to-windows-x64-release",
      "installDir": "${sourceDir}/out/install/linux-to-windows-x64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/linux-mingw-w64-x86_64.cmake",
        "ARS_ENABLE_TESTS": "OFF",
        "ARS_BUILD_APP": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-linux-ninja-release",
      "configurePreset": "linux-ninja-release"
    },
    {
      "name": "build-windows-vs2022-release",
      "configurePreset": "windows-vs2022-release",
      "configuration": "Release"
    },
    {
      "name": "build-linux-aarch64-release",
      "configurePreset": "linux-aarch64-release"
    },
    {
      "name": "build-linux-to-windows-x64-release",
      "configurePreset": "linux-to-windows-x64-release"
    }
  ],
  "testPresets": [
    {
      "name": "test-linux-ninja-release",
      "configurePreset": "linux-ninja-release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "test-windows-vs2022-release",
      "configurePreset": "windows-vs2022-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "test-linux-aarch64-release",
      "configurePreset": "linux-aarch64-release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "ignore"
      }
    }
  ]
}
