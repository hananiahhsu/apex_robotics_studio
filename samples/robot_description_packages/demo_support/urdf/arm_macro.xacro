<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="apex_arm" params="joint_name parent child length mesh_uri">
    <link name="${child}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${mesh_uri}" scale="1 1 1"/>
        </geometry>
      </visual>
    </link>
    <joint name="${joint_name}" type="revolute">
      <parent link="${parent}"/>
      <child link="${child}"/>
      <origin xyz="${length} 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.57" upper="1.57" effort="40" velocity="1.5"/>
    </joint>
  </xacro:macro>
</robot>
