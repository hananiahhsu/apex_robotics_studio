; ApexRoboticsStudio project file
; Schema versioned for interview and product-demo use

[project]
schema_version=3
project_name=InterviewPaintCellV09
robot_name=Apex Painter 6A

[metadata]
cell_name=Cell-Launch-01
process_family=painting
owner=manufacturing.engineering
notes=Interview-grade robot workstation scenario. Instantiated from governed project template.

[quality_gate]
require_collision_free=true
max_error_findings=0
max_warning_findings=2
max_peak_tcp_speed_mps=1.8
max_average_tcp_speed_mps=1.2
preferred_joint_velocity_limit_rad_per_sec=1.5

[joint]
