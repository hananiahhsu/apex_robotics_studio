<robot  name="DemoPainterXacro6A">
  
  

  
  
  
  <link name="base_link">
    <visual><geometry><mesh filename="package://apex_robotics_studio/meshes/base_link.dae" scale="1 1 1"/></geometry></visual>
    <collision><geometry><mesh filename="package://apex_robotics_studio/meshes/base_link.stl" scale="1 1 1"/></geometry></collision>
  </link>
  
    <joint name="joint_1" type="revolute">
      <origin xyz="0.450000 0 0" rpy="0 0 0"/>
      <limit lower="-3.140000" upper="3.140000" effort="100" velocity="1.5"/>
    </joint>
  
  
    <joint name="joint_2" type="revolute">
      <origin xyz="0.350000 0 0" rpy="0 0 0"/>
      <limit lower="-2.500000" upper="2.500000" effort="100" velocity="1.5"/>
    </joint>
  
  
    <joint name="joint_3" type="revolute">
      <origin xyz="0.300000 0 0" rpy="0 0 0"/>
      <limit lower="-2.500000" upper="2.500000" effort="100" velocity="1.5"/>
    </joint>
  
</robot>
